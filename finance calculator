<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>理财计算器</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap');
        body { font-family: 'Noto Sans SC', system-ui, sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <!-- 顶部标题 -->
    <header class="bg-white border-b sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-center gap-4">
            <div class="w-10 h-10 bg-sky-500 rounded-3xl flex items-center justify-center text-white text-3xl font-bold">算</div>
            <span class="text-4xl font-bold text-slate-900">理财计算器</span>
        </div>
    </header>

    <!-- 主内容 -->
    <section class="max-w-5xl mx-auto px-6 py-16">
        <div class="bg-white rounded-3xl shadow-2xl p-12">
            <div class="text-center mb-12">
                <h1 class="text-5xl font-bold">自定义投资组合</h1>
                <p class="text-slate-500 mt-4 text-xl">输入Yahoo符号（如 0700.HK、NVDA、600519.SS）→ 点击“获取真实数据”<br>支持自动提示 + 最稳定代理</p>
            </div>

            <div id="asset-list" class="space-y-8"></div>

            <div class="mt-12 flex justify-center gap-6">
                <button onclick="addAssetRow()" class="px-8 py-4 border border-sky-300 hover:bg-sky-50 text-sky-600 rounded-3xl flex items-center gap-3">
                    <i class="fa-solid fa-plus"></i> 添加第7个资产
                </button>
                <button onclick="calculatePortfolio()" class="px-12 py-4 bg-sky-600 hover:bg-sky-700 text-white text-xl font-medium rounded-3xl">
                    计算组合回报与风险
                </button>
            </div>

            <div class="mt-8 text-center text-3xl font-semibold text-sky-600" id="totalAlloc">100%</div>

            <!-- 结果区 -->
            <div id="portfolioResult" class="hidden mt-12 bg-sky-50 rounded-3xl p-10">
                <div class="grid grid-cols-2 gap-10 text-center">
                    <div><div class="text-sm text-slate-500">预期年化回报</div><div id="portReturn" class="text-6xl font-bold text-sky-700">—</div></div>
                    <div><div class="text-sm text-slate-500">预计波动率（风险）</div><div id="portVol" class="text-6xl font-bold text-rose-600">—</div></div>
                </div>
                <div class="mt-6 text-center text-sm text-slate-500">风险等级：<span id="riskLevel" class="font-medium text-sky-700"></span></div>
                <canvas id="allocPie" class="mx-auto mt-10" height="220"></canvas>
            </div>
        </div>
    </section>

    <!-- 自动提示列表 -->
    <datalist id="stockList">
        <option value="0700.HK">腾讯控股</option>
        <option value="600519.SS">贵州茅台</option>
        <option value="300750.SZ">宁德时代</option>
        <option value="9988.HK">阿里巴巴</option>
        <option value="1810.HK">小米集团</option>
        <option value="NVDA">英伟达</option>
        <option value="AAPL">苹果</option>
        <option value="TSLA">特斯拉</option>
        <option value="MSFT">微软</option>
        <option value="SPY">标普500 ETF</option>
        <option value="QQQ">纳斯达克100 ETF</option>
        <option value="ARKK">ARKK创新ETF</option>
    </datalist>

    <footer class="bg-slate-900 text-slate-400 py-12 text-center text-xs">
        © 2026 理财计算器 Vercel版 · 数据来自Yahoo Finance
    </footer>

    <script>
        let pieChart = null;
        let assets = [
            {id:1, name:"0700.HK", period:"3年", ret:11.5, vol:28, alloc:25},
            {id:2, name:"600519.SS", period:"5年", ret:22, vol:25, alloc:20},
            {id:3, name:"NVDA", period:"5年", ret:65, vol:42, alloc:15},
            {id:4, name:"SPY", period:"5年", ret:15, vol:17, alloc:15},
            {id:5, name:"现金", period:"3年", ret:2.8, vol:0.8, alloc:15},
            {id:6, name:"TSLA", period:"5年", ret:28, vol:52, alloc:10}
        ];

        function renderAssets() {
            const container = document.getElementById('asset-list');
            container.innerHTML = '';
            assets.forEach(asset => {
                const div = document.createElement('div');
                div.className = 'grid grid-cols-12 gap-4 items-end bg-slate-50 p-6 rounded-3xl';
                div.innerHTML = `
                    <div class="col-span-4">
                        <div class="text-xs text-slate-500 mb-1">Yahoo符号（必填）</div>
                        <input id="name${asset.id}" list="stockList" value="${asset.name}" class="w-full px-5 py-4 bg-white border border-slate-200 focus:border-sky-400 rounded-3xl text-lg" onchange="updateAsset(${asset.id})">
                    </div>
                    <div class="col-span-2">
                        <div class="text-xs text-slate-500 mb-1">年期</div>
                        <select id="period${asset.id}" class="w-full px-5 py-4 bg-white border border-slate-200 focus:border-sky-400 rounded-3xl text-lg" onchange="updateAsset(${asset.id})">
                            <option value="3年" ${asset.period==='3年'?'selected':''}>3年</option>
                            <option value="5年" ${asset.period==='5年'?'selected':''}>5年</option>
                            <option value="10年" ${asset.period==='10年'?'selected':''}>10年</option>
                        </select>
                    </div>
                    <div class="col-span-2">
                        <div class="text-xs text-slate-500 mb-1">年化回报 (%)</div>
                        <input id="ret${asset.id}" type="number" value="${asset.ret}" class="w-full px-5 py-4 bg-white border border-slate-200 focus:border-sky-400 rounded-3xl text-lg">
                    </div>
                    <div class="col-span-2">
                        <div class="text-xs text-slate-500 mb-1">波动率 (%)</div>
                        <input id="vol${asset.id}" type="number" value="${asset.vol}" class="w-full px-5 py-4 bg-white border border-slate-200 focus:border-sky-400 rounded-3xl text-lg">
                    </div>
                    <div class="col-span-2">
                        <div class="text-xs text-slate-500 mb-1">分配 (%)</div>
                        <input id="alloc${asset.id}" type="number" value="${asset.alloc}" oninput="updateTotalAlloc()" class="w-full px-5 py-4 bg-white border border-slate-200 focus:border-sky-400 rounded-3xl text-lg">
                    </div>
                    <div class="col-span-12 mt-3">
                        <button onclick="getRealData(${asset.id})" class="w-full py-3 bg-emerald-600 hover:bg-emerald-700 text-white rounded-3xl text-sm font-medium flex items-center justify-center gap-2">
                            <i class="fa-solid fa-satellite-dish"></i> 获取真实历史数据
                        </button>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        async function getRealData(id) {
            const btn = event.currentTarget;
            const original = btn.innerHTML;
            btn.innerHTML = '⏳ 获取中...';
            btn.disabled = true;

            const symbol = document.getElementById(`name${id}`).value.trim().toUpperCase();
            if (!symbol) {
                alert('请输入Yahoo符号');
                btn.innerHTML = original;
                btn.disabled = false;
                return;
            }

            const periodText = document.getElementById(`period${id}`).value;
            const years = periodText === '3年' ? 3 : periodText === '5年' ? 5 : 10;
            const end = Math.floor(Date.now() / 1000);
            const start = end - years * 365 * 24 * 3600;
            const yahooUrl = `https://query1.finance.yahoo.com/v8/finance/chart/${symbol}?period1=${start}&period2=${end}&interval=1mo`;
            const proxyUrl = `https://api.allorigins.win/raw?url=${encodeURIComponent(yahooUrl)}`;

            try {
                const res = await fetch(proxyUrl);
                const json = await res.json();
                const closes = json.chart.result[0].indicators.quote[0].close.filter(v => v != null);

                if (closes.length < 6) throw new Error('数据不足');

                const cagr = (Math.pow(closes[closes.length-1] / closes[0], 1/years) - 1) * 100;
                let rets = [];
                for (let i = 1; i < closes.length; i++) rets.push(Math.log(closes[i] / closes[i-1]));
                const mean = rets.reduce((a,b)=>a+b,0) / rets.length;
                const variance = rets.reduce((a,b)=>a + Math.pow(b-mean,2),0) / rets.length;
                const vol = Math.sqrt(variance) * Math.sqrt(12) * 100;

                document.getElementById(`ret${id}`).value = cagr.toFixed(1);
                document.getElementById(`vol${id}`).value = vol.toFixed(1);
                alert(`✅ ${symbol} ${years}年真实数据已填充！`);
            } catch(e) {
                alert('获取失败（代理偶尔限流），请稍等10秒重试');
            }
            btn.innerHTML = original;
            btn.disabled = false;
        }

        function updateAsset(id) {
            const idx = assets.findIndex(a => a.id === id);
            if (idx > -1) {
                assets[idx].name = document.getElementById(`name${id}`).value;
                assets[idx].period = document.getElementById(`period${id}`).value;
            }
        }

        function updateTotalAlloc() {
            let sum = 0;
            assets.forEach(a => {
                sum += parseFloat(document.getElementById(`alloc${a.id}`).value) || 0;
            });
            document.getElementById('totalAlloc').textContent = Math.round(sum);
        }

        function calculatePortfolio() {
            let totalRet = 0, variance = 0, totalAlloc = 0;
            assets.forEach(a => {
                const alloc = parseFloat(document.getElementById(`alloc${a.id}`).value) || 0;
                const ret = parseFloat(document.getElementById(`ret${a.id}`).value) || 0;
                const vol = parseFloat(document.getElementById(`vol${a.id}`).value) || 0;
                const w = alloc / 100;
                totalRet += w * ret;
                variance += w * w * vol * vol;
                totalAlloc += alloc;
            });

            if (Math.abs(totalAlloc - 100) > 5) return alert('分配比例请接近100%');

            const portVol = Math.sqrt(variance);
            const riskLevel = portVol < 12 ? '低风险' : portVol < 22 ? '中等风险' : '高风险';

            document.getElementById('portReturn').textContent = totalRet.toFixed(2) + '%';
            document.getElementById('portVol').textContent = portVol.toFixed(2) + '%';
            document.getElementById('riskLevel').textContent = riskLevel;
            document.getElementById('portfolioResult').classList.remove('hidden');

            const labels = assets.map(a => document.getElementById(`name${a.id}`).value);
            const data = assets.map(a => parseFloat(document.getElementById(`alloc${a.id}`).value) || 0);
            if (pieChart) pieChart.destroy();
            pieChart = new Chart(document.getElementById('allocPie'), {
                type: 'doughnut',
                data: { labels, datasets: [{ data, backgroundColor: ['#bae6fd','#7dd3fc','#38bdf8','#0ea5e9','#bae6fd','#7dd3fc'] }] },
                options: { plugins: { legend: { position: 'bottom' } } }
            });
        }

        function addAssetRow() {
            const newId = Math.max(...assets.map(a => a.id)) + 1;
            assets.push({id: newId, name:"AAPL", period:"5年", ret:26, vol:21, alloc:10});
            renderAssets();
            updateTotalAlloc();
        }

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            renderAssets();
            updateTotalAlloc();
            setTimeout(calculatePortfolio, 800);
        });
    </script>
</body>
</html>
